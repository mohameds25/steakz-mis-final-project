    {
      "name": "Branches",
      "item": [
        {
          "name": "List Branches",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/branches"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Branches returned\", function () { pm.response.to.be.success; });",
                  "const branches = pm.response.json();",
                  "for (const branch of branches) {",
                  "  const key = branch.city.toLowerCase().replace(/[^a-z0-9]/g, \"\");",
                  "  pm.environment.set(`${key}BranchId`, branch.id);",
                  "  pm.collectionVariables.set(`${key}BranchId`, branch.id);",
                  "}",
                  "const london = branches.find((branch) => branch.city === \"London\") || branches[0];",
                  "if (london) { pm.environment.set(\"branchId\", london.id); pm.collectionVariables.set(\"branchId\", london.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Branch",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/branches",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Steakz Oxford Lab\",\n  \"city\": \"Oxford\",\n  \"address\": \"10 High Street, Oxford\",\n  \"phone\": \"+44 1865 000 0606\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Branch created\", function () { pm.response.to.be.success; });",
                  "const body = pm.response.json();",
                  "const records = Array.isArray(body) ? body : [body];",
                  "const selected = records[0];",
                  "if (selected && selected.id) { pm.environment.set(\"branchId\", selected.id); pm.collectionVariables.set(\"branchId\", selected.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Branch",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/branches/{{branchId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Steakz Oxford Lab Updated\",\n  \"city\": \"Oxford\",\n  \"address\": \"12 High Street, Oxford\",\n  \"phone\": \"+44 1865 000 0607\"\n}"
            }
          },
