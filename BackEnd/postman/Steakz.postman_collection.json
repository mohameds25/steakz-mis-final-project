            ],
            "url": "{{baseUrl}}/api/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Orders returned\", function () { pm.response.to.be.success; });",
                  "const orders = pm.response.json();",
                  "const records = Array.isArray(orders) ? orders : [orders];",
                  "const first = records[0];",
                  "if (first?.id) { pm.environment.set(\"orderId\", first.id); pm.collectionVariables.set(\"orderId\", first.id); }",
                  "const nonLondon = records.find((order) => order.branch && order.branch.city !== \"London\");",
                  "if (nonLondon?.id) { pm.environment.set(\"otherBranchOrderId\", nonLondon.id); pm.collectionVariables.set(\"otherBranchOrderId\", nonLondon.id); }"
                ]
              }
            }
          ]
        },
